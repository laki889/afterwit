#!/bin/sh
''':'
# sh/python polyglot: this half runs under sh (macOS, Linux, Git Bash on
# Windows), probes for a WORKING interpreter, and re-execs this same file
# with it. The `-c ""` probe rejects the Windows Store alias stub, which
# sits on PATH pretending to be python3 but only opens the Store.
if python3 -c "" >/dev/null 2>&1; then exec python3 "$0" "$@"; fi
if python -c "" >/dev/null 2>&1; then exec python "$0" "$@"; fi
echo "afterwit: no usable python3/python found on PATH" >&2
exit 1
':'''
"""Launcher for the bundled afterwit package (no install step needed).

Lives in the plugin's bin/ directory, which Claude Code adds to the Bash
tool's PATH inside sessions; outside sessions run it directly or symlink it
somewhere on your PATH. The whole file is also valid Python, so
`python <path>/afterwit` works anywhere sh doesn't (e.g. PowerShell).
"""

import os
import sys

sys.path.insert(
    0, os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "src")
)

from afterwit.cli import main  # noqa: E402

main()
